<section class="card">
    <h3>Генерація Release Notes</h3>
    <p class="muted">Оберіть підключення GitHub і вкажіть два теги або SHA (Base → Target). Для <b>усіх комітів</b> — <code>*</code> в обох полях (ліміт <code>GitHub:MaxFullHistoryCommits</code>). Дані беруться через GitHub API, без clone. Токен — у підключенні або <code>GitHub:Token</code>.</p>

    <EditForm Model="_model" OnValidSubmit="GenerateAsync" FormName="generate-release-notes-form">
        <DataAnnotationsValidator />
        <div class="form-grid">
            <div class="field field-span-full">
                <label>Репозиторій (із бази)</label>
                <InputSelect @bind-Value="_model.RepositoryConnectionId">
                    <option value="@Guid.Empty">— Оберіть підключення —</option>
                    @foreach (var r in ActiveGithubRepositories)
                    {
                        <option value="@r.Id">@r.DisplayName (@r.RepositoryPath)</option>
                    }
                </InputSelect>
            </div>
            <div class="field">
                <label>Base Tag</label>
                <InputText @bind-Value="_model.BaseTag" placeholder="* = усі коміти" />
            </div>
            <div class="field">
                <label>Target Tag</label>
                <InputText @bind-Value="_model.TargetTag" placeholder="* = усі коміти" />
            </div>
        </div>
        <div class="actions">
            <button class="btn" type="submit" disabled="@IsGenerating">@( IsGenerating ? "Генерація..." : "Згенерувати")</button>
            @if (!string.IsNullOrWhiteSpace(_status))
            {
                <p class="status @StatusClass">@_status</p>
            }
        </div>
    </EditForm>

    @if (_document is not null)
    {
        <div class="results">
            <article class="card">
                <h4>Згенерований документ</h4>
                <p><b>Repository:</b> @_document.Repository</p>
                <p><b>Range:</b> @_document.BaseTag → @_document.TargetTag</p>
                <p><b>Generated:</b> @_document.GeneratedAt.LocalDateTime.ToString("g")</p>
                @if (!string.IsNullOrWhiteSpace(_document.AiSummary))
                {
                    <p class="ai-summary"><b>Підсумок:</b> @_document.AiSummary</p>
                }
                <h5 class="commits-heading">Коміти (@_commitsTotal)</h5>
                @if (_commitsTruncated)
                {
                    <p class="muted">Показано перші @_commitsForUi.Count з @_commitsTotal (обмеження UI).</p>
                }
                <div class="commits-scroll">
                    <table class="commits-table">
                        <thead>
                            <tr>
                                <th>Дата</th>
                                <th>SHA</th>
                                <th>Повідомлення</th>
                                <th>Категорія</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var e in _commitsForUi)
                            {
                                <tr>
                                    <td class="commit-date-cell">@(FormatCommitDate(e.CommittedAt))</td>
                                    <td class="mono">
                                        @if (CommitUrl(e.SourceId) is { } linkUrl)
                                        {
                                            <a href="@linkUrl" target="_blank" rel="noopener noreferrer">@ShortHash(e.SourceId)</a>
                                        }
                                        else
                                        {
                                            @ShortHash(e.SourceId)
                                        }
                                    </td>
                                    <td>@e.Summary</td>
                                    <td>@e.Category</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </article>
        </div>
    }
</section>
